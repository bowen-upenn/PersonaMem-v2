import matplotlib.pyplot as plt
import matplotlib.patches as patches
import numpy as np

# Correct Data
labels = [
    "Qwen3-4B-Memory", "Qwen3-4B-GRPO", "GPT-5-mini", "GPT-5-chat",
    "o4-mini", "GPT-4.1", "GPT-5-nano", "GPT-4.1-mini",
    "Qwen3-4B-SFT", "Qwen3-4B-base"
]
values = [55.4, 53.8, 47.3, 45.6, 39.1, 38.7, 37.9, 37.6, 32.0, 26.8]
title = "PersonaMem-v2"
subtitle = "Long-context Personalization"

# 1. Combine and Sort Data
sorted_data = sorted(zip(values, labels), reverse=True)
sorted_values = [v for v, l in sorted_data]
sorted_labels = [l for v, l in sorted_data]

# 2. Define Colors (MODIFIED: Lighter blue for the highest Qwen model)
BRIGHT_BLUE_NEW = '#3366CC' # Slightly lighter blue than previous DARKER_BLUE
LIGHTER_GRAY = '#E0E0E0'

qwen_models_data = [(v, l) for v, l in zip(sorted_values, sorted_labels) if "Qwen" in l]
qwen_values = [v for v, l in qwen_models_data]

if qwen_values:
    max_qwen_val = max(qwen_values)
    min_qwen_val = min(qwen_values)
    
    from matplotlib.colors import LinearSegmentedColormap
    # Define the custom colormap: from very light blue to the new BRIGHT_BLUE
    cmap_blue = LinearSegmentedColormap.from_list("qwen_blues_gradient", ['#A8D4FF', BRIGHT_BLUE_NEW])
    
    qwen_colors = {}
    for value, label in qwen_models_data:
        normalized_val = (value - min_qwen_val) / (max_qwen_val - min_qwen_val) if max_qwen_val != min_qwen_val else 1.0
        qwen_colors[label] = cmap_blue(normalized_val)
else:
    qwen_colors = {}

final_bar_colors = []
for label in sorted_labels:
    final_bar_colors.append(qwen_colors[label]) if "Qwen" in label else final_bar_colors.append(LIGHTER_GRAY)

# 3. Setup the Plot - Set background transparent
fig, ax = plt.subplots(figsize=(12, 6))
fig.patch.set_alpha(0.0)
ax.patch.set_alpha(0.0)

# 4. Create the Bar Chart with rounded edges (FancyBboxPatch)
rects = ax.bar(sorted_labels, [0]*len(sorted_values), color='none')

custom_patches = []
bar_width = rects[0].get_width()

for i, (value, color) in enumerate(zip(sorted_values, final_bar_colors)):
    x_pos = rects[i].get_x()
    
    bar_patch = patches.FancyBboxPatch(
        (x_pos, 0), bar_width, value,
        boxstyle="round,pad=0,rounding_size=0.3", # Rounded corners
        facecolor=color,
        edgecolor=color,
    )
    ax.add_patch(bar_patch)
    custom_patches.append(bar_patch)

# 5. Add Title and Subtitle
fig.suptitle(title, fontsize=20, fontweight='bold', ha='left', x=0.1, y=1.02)
ax.set_title(subtitle, fontsize=14, color='gray', ha='left', x=-0.01, y=1.01)

# 6. Customize the Axes
ax.set_ylim(20, 60)
ax.set_ylabel('Accuracy (%)', fontsize=12, fontweight='bold', labelpad=15)
ax.yaxis.set_visible(True)
ax.spines['left'].set_visible(True)
ax.tick_params(axis='y', length=0)

ax.spines['right'].set_visible(False)
ax.spines['top'].set_visible(False)
ax.spines['bottom'].set_linewidth(1.5)
plt.xticks(rotation=45, ha='right')

# 7. Add Data Values on top of each bar
for patch, value in zip(custom_patches, sorted_values):
    x_center = patch.get_x() + patch.get_width() / 2
    
    ax.annotate(f'{value:.1f}%',
                xy=(x_center, value),
                xytext=(0, 3),
                textcoords="offset points",
                ha='center', va='bottom',
                fontsize=12, fontweight='bold')

# 8. Add Dashed Line (MODIFIED: Removed text annotation)
ax.axhline(y=25, color='gray', linestyle='--', linewidth=1.5, zorder=10)


plt.tight_layout(rect=[0, 0.05, 1, 0.95])

# Save the plot with transparent background
plt.savefig('PersonaMem_v2_histogram_final_v3.png', transparent=True)
