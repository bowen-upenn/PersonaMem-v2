# Environment configuration for LLM persona extraction pipeline
# Copy this file to .env and fill in your API credentials

# Option 1: OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-chat
OPENAI_MODEL_EMBED=text-embedding-3-large

# # Option 2: Azure OpenAI Configuration (alternative to OpenAI)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=your_azure_openai_key
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-chat
# AZURE_OPENAI_API_VERSION=your_azure_openai_api_version_of_gpt-5-chat
# AZURE_OPENAI_DEPLOYMENT_NAME_EMBED=text-embedding-3-large
# AZURE_OPENAI_API_VERSION_EMBED=your_azure_openai_api_version_of_text-embedding-3-large

# Notes:
# - You need either OpenAI OR Azure OpenAI configuration, not both
# - The pipeline will try Azure OpenAI first, then fall back to OpenAI
# - For OpenAI: Only OPENAI_API_KEY is required, OPENAI_MODEL defaults to gpt-4
# - For Azure OpenAI: AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_KEY, and AZURE_OPENAI_DEPLOYMENT_NAME are required
